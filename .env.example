# =============================================================================
# RTT-IT — variáveis de ambiente (produção / Docker)
# Copie para .env e preencha. NÃO commite o .env com segredos.
# =============================================================================

# Obrigatório em produção (gere uma chave forte, ex.: openssl rand -hex 32)
DJANGO_SECRET_KEY=

# Lista separada por vírgulas (domínio público ou IP do VPS)
ALLOWED_HOSTS=app.exemplo.com,www.app.exemplo.com

# HTTPS atrás de proxy (Nginx / EasyPanel) — recomendado: 1
USE_X_FORWARDED_PROTO=1

# Origens para CSRF (HTTPS), separadas por vírgula
# Ex.: https://app.exemplo.com,https://www.app.exemplo.com
CSRF_TRUSTED_ORIGINS=

# Cookies seguros (HTTPS). Se testar só em HTTP, use 0
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1

# -----------------------------------------------------------------------------
# PostgreSQL EXTERNO (criado à parte no EasyPanel — não pelo container da app)
# -----------------------------------------------------------------------------
# Opção A — variáveis separadas (recomendado no EasyPanel: copiar host do serviço Postgres)
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# Opção B — uma única URL (o entrypoint converte automaticamente para DB_*)
# DATABASE_URL=postgresql://USER:SENHA@HOST_DO_POSTGRES:5432/NOME_BD

# Opção C — nomes típicos de imagem Postgres (também mapeados automaticamente)
# POSTGRES_HOST=
# POSTGRES_DB=
# POSTGRES_USER=
# POSTGRES_PASSWORD=
# POSTGRES_PORT=5432

# Opcional
DB_CONN_MAX_AGE=60
DB_CONNECT_TIMEOUT=10

# -----------------------------------------------------------------------------
# Gunicorn
# -----------------------------------------------------------------------------
GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120

# Logs: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
