# =============================================================================
# RTT-IT — produção / Docker (apenas SQLite)
# =============================================================================

DJANGO_SECRET_KEY=

ALLOWED_HOSTS=app.exemplo.com

# SQLite no volume montado em /app/media (EasyPanel bind mount)
SQLITE_PATH=/app/media/db.sqlite3

USE_X_FORWARDED_PROTO=1
CSRF_TRUSTED_ORIGINS=

SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1

GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120

LOG_LEVEL=INFO
